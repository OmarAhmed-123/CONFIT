# CONFIT Frontend Environment Configuration
# Copy this file to .env.local and fill in your values

# ===========================================
# API Configuration
# ===========================================
# Backend FastAPI URL (required)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# ===========================================
# Authentication - NextAuth.js
# ===========================================
# Required for JWT session encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Your app URL (required for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# Public site URL (Open Graph, metadataBase)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Where SocialLoginButtons send users for legacy/social OAuth routes (usually same as API or auth service)
NEXT_PUBLIC_AUTH_ORIGIN=http://localhost:8001

# ===========================================
# Authentication - OAuth Providers
# ===========================================
# Google OAuth (get from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple Sign-In (get from Apple Developer Portal)
# https://developer.apple.com/account/resources/identifiers/list
NEXT_PUBLIC_APPLE_CLIENT_ID=com.yourcompany.confit
APPLE_CLIENT_SECRET=your-apple-client-secret

# ===========================================
# Payment Integration
# ===========================================
# Stripe Publishable Key (get from Stripe Dashboard)
# https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ===========================================
# Feature Flags
# ===========================================
NEXT_PUBLIC_ENABLE_VIRTUAL_TRYON=true
NEXT_PUBLIC_ENABLE_BNPL=true
NEXT_PUBLIC_ENABLE_CONFIT_CARE=true

# ===========================================
# Analytics & Monitoring (Optional)
# ===========================================
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_SENTRY_DSN=
