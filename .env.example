# CONFIT Frontend — Environment Variables
# Copy this file to .env.local and fill in values for your environment.
# NEVER commit .env.local to version control — it is git-ignored.
#
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# URL of the CONFIT backend API (no trailing slash)
VITE_API_URL=http://localhost:8000

# Virtual try-on: max wait for POST /api/virtual-tryon/process (default 180000 ms)
# VITE_TRYON_TIMEOUT_MS=180000
VITE_TRYON_PREVIEW_TIMEOUT_MS=15000
VITE_TRYON_RENDER_POLL_MS=1500
VITE_TRYON_RENDER_MAX_WAIT_MS=180000

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE (required for Supabase-backed features)
# ─────────────────────────────────────────────────────────────────────────────

# Your Supabase project URL — found in Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Feature flags & third-party integrations
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to enable verbose API request logging in the browser console
VITE_DEBUG_API=false

# Stripe publishable key (for payment UI — not secret)
# VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Google Maps API key (for Store Locator feature)
# VITE_GOOGLE_MAPS_KEY=AIza...

# Sentry DSN for frontend error tracking (optional)
# VITE_SENTRY_DSN=https://...@sentry.io/...

# Application environment — affects error boundaries and logging verbosity
# Values: development | staging | production
VITE_ENV=development

# Google Gemini (browser-side features, e.g. geminiService.ts)
# Keep this in your local `.env` only; never commit real keys.
# VITE_GEMINI_API_KEY=your-gemini-api-key
