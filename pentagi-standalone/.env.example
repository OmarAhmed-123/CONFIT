# PentAGI — copy to `pentagi.env` and fill in. Do not commit `pentagi.env`.
# Align AI keys with CONFIT backend: same variable names where possible.

# Required: At least one LLM provider
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key

# Security APIs
SHODAN_API_KEY=your-shodan-api-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key

DUCKDUCKGO_ENABLED=true

PENTAGI_POSTGRES_USER=pentagi
PENTAGI_POSTGRES_PASSWORD=
PENTAGI_POSTGRES_DB=pentagidb

COOKIE_SIGNING_SALT=
PENTAGI_API_TOKEN=

PUBLIC_URL=https://localhost:8443
SERVER_HOST=0.0.0.0
SERVER_PORT=8443
