NODE_ENV=development
PORT=4000
PUBLIC_APP_ORIGIN=http://localhost:3000
REDIS_URL=redis://localhost:6379
COOKIE_SECRET=replace-with-32+chars-random

JWT_ISSUER=confit
JWT_AUDIENCE=confit-web
JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Google (OIDC)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:4000/auth/callback/google

# Facebook
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_FACEBOOK_REDIRECT_URI=http://localhost:4000/auth/callback/facebook

# Instagram
OAUTH_INSTAGRAM_CLIENT_ID=
OAUTH_INSTAGRAM_CLIENT_SECRET=
OAUTH_INSTAGRAM_REDIRECT_URI=http://localhost:4000/auth/callback/instagram

# X (Twitter)
OAUTH_X_CLIENT_ID=
OAUTH_X_CLIENT_SECRET=
OAUTH_X_REDIRECT_URI=http://localhost:4000/auth/callback/x

# TikTok
OAUTH_TIKTOK_CLIENT_ID=
OAUTH_TIKTOK_CLIENT_SECRET=
OAUTH_TIKTOK_REDIRECT_URI=http://localhost:4000/auth/callback/tiktok

# Stripe (optional; if empty, payments use mock confirm)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AI Provider Keys (optional; required only for /api/integrations/ai/chat)
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
HUGGINGFACE_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Development-only fallback: if provider creds are missing,
# /auth/:provider issues a local mock authenticated session.
DEV_OAUTH_MOCK_ENABLED=true

