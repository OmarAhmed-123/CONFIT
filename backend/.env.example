# Backend Configuration
# =====================
# Copy this file to .env for local development

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=development
DEBUG=true

# Server settings
HOST=0.0.0.0
PORT=8000
# If you see WinError 10048 / "address already in use": another process holds PORT (often an old
# backend). Stop it or set PORT=8001. Optional: SKIP_PORT_PREFLIGHT=1 to skip the bind check.
# WinError 10013 on bind: try PORT=8001 or HOST=127.0.0.1, or check excluded port ranges (netsh).
# BACKEND_RELOAD=true  # dev only — needs ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Database URL (SQLite for development, PostgreSQL for production)
# SQLite: sqlite:///./confit.db
# PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///./confit.db

# PostgreSQL Credentials (for docker-compose.postgres.yml)
POSTGRES_USER=confit
POSTGRES_PASSWORD=
POSTGRES_DB=confit
POSTGRES_PORT=5432

# Connection Pool Settings (PostgreSQL only)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ─────────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────────

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=change-me-in-production-min-32-characters-secure
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# Secret Key for encryption (REQUIRED IN PRODUCTION)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-chars-required-in-production

# Style DNA Encryption Key (Optional - will derive from SECRET_KEY if not set)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STYLE_DNA_ENCRYPTION_KEY=

# Body DNA — encrypted per-user measurements (defaults to ./data/body_dna under cwd)
BODY_DNA_STORAGE_PATH=

# Classical try-on — CPU GrabCut fallback when MediaPipe selfie is unavailable (lower = faster)
TRYON_GRABCUT_MAX_SIDE=384
TRYON_GRABCUT_ITERS=2

# Hard cap for POST /api/virtual-tryon/process (seconds); returns HTTP 504 when exceeded
TRYON_REQUEST_TIMEOUT_SEC=300
TRYON_PREVIEW_TIMEOUT_SEC=20
TRYON_HEALTHCHECK_TIMEOUT_SEC=5
TRYON_MAX_IMAGE_MB=12

# Optional: if the primary garmentImageUrl fails (404, timeout), retry once with this URL (e.g. stable catalog image).
# TRYON_FALLBACK_GARMENT_IMAGE_URL=https://images.unsplash.com/photo-1576566588028-4147f3842f27?w=400

# Keep person image at upload resolution (default 1). Set 0 to downscale with TRYON_PERSON_MAX_SIDE.
TRYON_PRESERVE_UPLOAD_RESOLUTION=1
TRYON_PERSON_MAX_SIDE=1024

# Extra garment warp alignment attempts (each can add ~60–90s on CPU). Default 0 = single warp.
TRYON_WARP_ALIGN_MAX_RETRIES=0
# Minimum garment alpha area / torso area before auto-upscale kicks in.
TRYON_MIN_TORSO_COVERAGE=0.18

# Garment catalog matting (GrabCut + guided alpha; reduces “Garment visibility low” warnings)
TRYON_GARMENT_GRABCUT=1
TRYON_GARMENT_GRABCUT_ITERS=3
TRYON_GARMENT_GUIDED_ALPHA=1
TRYON_GARMENT_GUIDED_RADIUS=6
TRYON_GARMENT_GUIDED_EPS=0.001

# MediaPipe Tasks models cache (~20–40 MB first run). Override URLs only if mirroring.
# MEDIAPIPE_MODEL_CACHE_DIR=
# TRYON_POSE_LANDMARKER_MODEL_URL=https://storage.googleapis.com/mediapipe-models/pose_landmarker/pose_landmarker_lite/float16/latest/pose_landmarker_lite.task
# TRYON_SELFIE_SEGMENTER_MODEL_URL=https://storage.googleapis.com/mediapipe-models/image_segmenter/selfie_multiclass_256x256/float32/latest/selfie_multiclass_256x256.tflite

# Skip MediaPipe Tasks GPU delegate for the whole process after failures, or force CPU from the start (Windows wheels often log "GPU processing is disabled in build flags").
# TRYON_FORCE_CPU=1
# MEDIAPIPE_USE_GPU=0

# Debug: save pose/garment/warp/final under debug_output/<request_id>/ (also alignment_meta.json with angles and version).
# DEBUG_TRYON=1
# DEBUG_TRYON_DIR=debug_output
# DEBUG_TRYON_MAX_SAVES=48

# Reject try-on responses below this composite score (avoids returning glitched images). Override per-request via options.minOutputQuality.
TRYON_MIN_OUTPUT_QUALITY=

# Region compositor — feather on garment alpha only (3–9 typical); face/hair protection dilation
# Set to 1 only if you need legacy “torso-only” alpha gating (can shrink warped shirts to a chest patch).
# TRYON_BLEND_STRICT_TORSO_GATE=0
TRYON_BLEND_FEATHER_PX=5
TRYON_PROTECT_DILATE_ITERS=2
TRYON_PROTECT_KERNEL=5
TRYON_FACE_SHARPNESS_MIN_RATIO=0.82

# Quality pipeline — weighted composite (see services/tryon/quality.py)
TRYON_QUALITY_RECOVERY_MAX=2
TRYON_SEG_CONF_LOW=0.5
TRYON_INPUT_PREPROCESS=1
TRYON_PREPROCESS_CLAHE_CLIP=2.0
TRYON_PREPROCESS_DENOISE_MAX_SIDE=640

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────

# CORS - Frontend URL (adjust if your frontend runs on a different port)
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# AI SERVICES (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Virtual Stylist - Groq AI (Optional)
# Get a free API key at: https://console.groq.com/keys
# If not set, the stylist will use a smart rule-based fallback
GROQ_API_KEY=

# HuggingFace Token (Optional - for priority queue access)
# Get a free token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Virtual try-on — cloud image generation (recommended: Gemini free tier)
# Get GEMINI_API_KEY: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model id (defaults work for most accounts); optional fallbacks: GEMINI_TRYON_MODEL_FALLBACKS
GEMINI_TRYON_MODEL=gemini-2.5-flash-image
# Optional legacy: Lovable OpenAI-compatible gateway
LOVABLE_API_KEY=
AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1/chat/completions
# auto | gemini | lovable
TRYON_GATEWAY_PROVIDER=auto
# Classical try-on PBD fabric drape: unset = auto (off on CPU, on when CUDA GPU); 0=off 1=on
TRYON_FABRIC_PHYSICS=

# OpenAI API Key (Optional)
OPENAI_API_KEY=

DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Google AI / Gemini — backend try-on & tools typically use GEMINI_API_KEY above.
# Some scripts accept GOOGLE_API_KEY as an alternate name; set one consistently.
GOOGLE_API_KEY=

# FASHN virtual try-on API (https://docs.fashn.ai) — preferred when set
FASHN_API_KEY=
# Optional: explicit FASHN endpoint
FASHN_API_BASE=https://api.fashn.ai/v1
FASHN_TRYON_MODEL=tryon-v1.6
# Virtual Try-On production safety:
# - Keep classical fallback OFF by default (avoid unrealistic sticker-like outputs)
# - Turn ON only for debugging or emergency fallback
TRYON_ALLOW_CLASSICAL_FALLBACK=0

# Bump this when try-on pipeline logic changes to avoid stale in-memory/redis cache reuse.
TRYON_PIPELINE_VERSION=2026-03-23-idm-vton-mask-identity-v2

# ---------------------------------------------------------------------------
# Remote self-hosted GPU render adapter (free-first, optional)
# ---------------------------------------------------------------------------
# Full remote final-render endpoint (POST JSON):
#   {
#     "userImageBase64": "...",
#     "garmentImageUrl": "...",
#     "garmentName": "...",
#     "garmentCategory": "tops|bottoms|dresses|..."
#   }
# Expected response includes: resultImage OR result_image
TRYON_REMOTE_URL=

# Optional explicit health endpoint; defaults to <remote host>/health
TRYON_REMOTE_HEALTH_URL=

# Optional auth for remote endpoint
TRYON_REMOTE_API_KEY=
TRYON_REMOTE_AUTH_HEADER=Authorization
TRYON_REMOTE_AUTH_SCHEME=Bearer

# Optional extra headers as JSON object string
# TRYON_REMOTE_EXTRA_HEADERS_JSON={"X-Org":"my-org"}
TRYON_REMOTE_EXTRA_HEADERS_JSON=

# Network / retry behavior
TRYON_REMOTE_TIMEOUT_SEC=180
TRYON_REMOTE_HEALTH_TIMEOUT_SEC=2.5
TRYON_REMOTE_RETRIES=2
TRYON_REMOTE_RETRY_BACKOFF_SEC=0.8
TRYON_REMOTE_PREFERRED=1

# Local neural backend skeleton (CatVTON / IDM-VTON)
TRYON_LOCAL_MODEL_PATH=
TRYON_LOCAL_MODEL_TYPE=catvton
TRYON_LOCAL_BATCH_SIZE=1
TRYON_LOCAL_MODELS_DIR=E:/CONFIT/backend/models
TRYON_BACKEND_PRIORITY=local_catvton,local_idmvton,remote_gpu,replicate,fashn,huggingface_space,preview_only

# Local mock remote server (for free end-to-end testing)
# Start with: python mock_remote_gpu_server.py
# TRYON_REMOTE_URL=http://127.0.0.1:8011/render
# TRYON_REMOTE_HEALTH_URL=http://127.0.0.1:8011/health
# TRYON_REMOTE_MOCK_HOST=127.0.0.1
# TRYON_REMOTE_MOCK_PORT=8011

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENTS (Optional)
# ─────────────────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=change-me-min-32-chars-required-in-production
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# Allow mock Stripe intents in development only (default: false).
# Set to true ONLY for local dev without real Stripe keys.
ALLOW_MOCK_PAYMENTS=false
# Stripe use case for Egypt: "international_customers_only" | "disabled" | "all"
# For Egypt-based CONFIT, Stripe is only for non-EGP or non-EG customers
STRIPE_USE_CASE=international_customers_only

# ─────────────────────────────────────────────────────────────────────────────
# PAYMOB ACCEPT — payment_keys + iframe (used by services/payment_platform/providers/paymob_provider.py)
# Copy real values into backend/.env only. Never commit .env.
# Flow: PAYMOB_API_KEY → auth token → register order → POST /acceptance/payment_keys → iframe_token in API response.
# ─────────────────────────────────────────────────────────────────────────────
# https://accept.paymob.com/ → Developers → Authentication → API Key (JWT string)
PAYMOB_API_KEY=your-paymob-api-key-here

# Your card/iframe integration → Integration ID (integer)
PAYMOB_INTEGRATION_ID=your-integration-id

# Egypt-specific integration IDs (get from Paymob dashboard)
# 3D Secure cards
PAYMOB_INTEGRATION_ID_3DS=
# Meeza cards (Egypt local card scheme)
PAYMOB_INTEGRATION_ID_MEEZA=
# Instapay bank transfers
PAYMOB_INTEGRATION_ID_INSTAPAY=
# Valu BNPL (6/9/12/18/24 month installments)
PAYMOB_INTEGRATION_ID_VALU=
# Fawry payment
PAYMOB_INTEGRATION_ID_FAWRY=

# Webhook HMAC verification (services/payment_platform/providers/paymob_provider.py verify_callback_hmac)
PAYMOB_HMAC_SECRET=your-hmac-secret
# If HMAC alone fails verification, set to Egypt "Secret key" (egy_sk_...)
PAYMOB_SECRET_KEY=egy_sk_test_your-secret-key

# Optional: egy_pk_... — returned to frontend in unified session as "public_key" only
PAYMOB_PUBLIC_KEY=egy_pk_test_your-public-key
# Iframe numeric id (shown in Paymob iframe URL). Needed for full "iframe_url" in session response.
PAYMOB_IFRAME_ID=your-iframe-id
# Optional:
# PAYMOB_BASE_URL=https://accept.paymob.com/api
# PAYMOB_IFRAME_URL=https://accept.paymob.com/api/acceptance/iframes
# Production: Paymob integration → Transaction response callback → https://YOUR_HOST/api/payments/unified/webhooks/paymob


# If HMAC alone fails verification, set to Egypt “Secret key” (egy_sk_...)


# ─────────────────────────────────────────────────────────────────────────────
# PAYPAL REST (Orders v2) — used by services/payment_platform/providers/paypal_provider.py
# Get credentials: https://developer.paypal.com/dashboard/applications (Sandbox or Live app)
# Flow: CLIENT_ID + CLIENT_SECRET → OAuth → create order → user approves → POST .../paypal/capture → webhooks optional
# ─────────────────────────────────────────────────────────────────────────────
# Application "Client ID" from PayPal Developer Dashboard
PAYPAL_CLIENT_ID=your-paypal-client-id

# Application "Secret" (under the same app; not the Paymob secret)
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# sandbox | live — must match the app that issued the Client ID / Secret above
PAYPAL_MODE=sandbox
# Developer Dashboard → your app → Webhooks → create webhook pointing to /api/payments/unified/webhooks/paypal → copy Webhook ID
PAYPAL_WEBHOOK_ID=your-webhook-id

# Application “Client ID” from PayPal Developer Dashboard

# Application “Secret” (under the same app; not the Paymob secret)


# ─────────────────────────────────────────────────────────────────────────────
# FAWRY PAYMENT PROVIDER
# ─────────────────────────────────────────────────────────────────────────────
# Fawry API Key
FAWRY_API_KEY=your-fawry-api-key
# Fawry API Secret
FAWRY_API_SECRET=your-fawry-api-secret
# Fawry Merchant Code
FAWRY_MERCHANT_CODE=your-fawry-merchant-code
# Fawry Payment Type
FAWRY_PAYMENT_TYPE=your-fawry-payment-type

# ─────────────────────────────────────────────────────────────────────────────
# INVOICES (PDF storage)
# ─────────────────────────────────────────────────────────────────────────────
# INVOICE_STORAGE_DIR=

# ─────────────────────────────────────────────────────────────────────────────
# OAUTH (Optional)
# ─────────────────────────────────────────────────────────────────────────────

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# MONITORING (Optional)
# ─────────────────────────────────────────────────────────────────────────────

SENTRY_DSN=
LOG_LEVEL=INFO

# Protects /api/metrics and other internal observability endpoints
# Must be ≥32 characters in production. Leave empty in dev to allow local access.
INTERNAL_API_KEY=

# Prometheus & Grafana (docker-compose local monitoring)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ─────────────────────────────────────────────────────────────────────────────
# ELASTICSEARCH (Optional)
# ─────────────────────────────────────────────────────────────────────────────

ELASTICSEARCH_URL=http://localhost:9200

# ─────────────────────────────────────────────────────────────────────────────
# USER SEEDING (Development Only)
# ─────────────────────────────────────────────────────────────────────────────

# Demo user password (only used in development when DB is empty)
# If not set, a random password will be generated and logged
DEMO_PASSWORD=

# Admin user (requires both email and password to be set)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL APIS (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Weather API for outfit recommendations
OPENWEATHERMAP_API_KEY=
WEATHERAPI_KEY=

# Calendar integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# PENTAGI - AI PENETRATION TESTING PLATFORM
# ─────────────────────────────────────────────────────────────────────────────

# PentAGI API Token (generate from PentAGI UI > Settings > API Tokens)
PENTAGI_API_TOKEN=

# PentAGI Connection Settings
PENTAGI_URL=https://pentagi:8443
PENTAGI_SSL_VERIFY=true
PENTAGI_PORT=8443

# PentAGI PostgreSQL Database
PENTAGI_POSTGRES_USER=pentagi
PENTAGI_POSTGRES_PASSWORD=your-secure-password-here
PENTAGI_POSTGRES_DB=pentagidb

# Optional: PentAGI scraper (only if you run the scraper sidecar/service)
PENTAGI_SCRAPER_PRIVATE_URL=
PENTAGI_SCRAPER_USERNAME=
PENTAGI_SCRAPER_PASSWORD=

# AI Provider - DeepSeek (Primary)
DEEPSEEK_SERVER_URL=https://api.deepseek.com


## OpenAI (Optional fallback)
OPEN_AI_SERVER_URL=https://api.openai.com/v1

## Anthropic (Optional fallback)
ANTHROPIC_SERVER_URL=https://api.anthropic.com/v1

## Google Gemini (Optional fallback)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_SERVER_URL=https://generativelanguage.googleapis.com


# Required: At least one LLM provider
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Security APIs
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=

# # -------------------------------------------------------------------------
# NOTIFICATION INTEGRATIONS
# # -------------------------------------------------------------------------

# Firebase Cloud Messaging (FCM) - Push Notifications
# Get service account JSON from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-service-account.json

# Twilio WhatsApp Business API
# IMPORTANT: Use Twilio for WhatsApp ONLY, NOT for SMS in Egypt (10x more expensive)
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SMS Provider Selection (infobip | vodafone | victorylink)
# Recommended: Infobip for reliability, VictoryLink for OTP (cheapest)
SMS_PROVIDER=infobip

# Infobip SMS Gateway (Recommended for Egypt)
# Get credentials from: https://portal.infobip.com
INFOBIP_API_KEY=your-infobip-api-key
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_SENDER_ID=CONFIT

# Vodafone Egypt SMS Gateway
# Contact Vodafone Egypt Business for credentials
VODAFONE_SMS_USERNAME=your-vodafone-sms-username
VODAFONE_SMS_PASSWORD=your-vodafone-sms-password
VODAFONE_SENDER=CONFIT
VODAFONE_SMS_URL=https://sms.vodafone.com.eg

# VictoryLink Egypt SMS Gateway (Best for OTP)
# Contact VictoryLink Egypt for credentials
VICTORYLINK_API_KEY=your-victorylink-api-key
VICTORYLINK_SENDER_ID=CONFIT
VICTORYLINK_BASE_URL=https://api.victorylink.com

# SendGrid Transactional Email
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@confit.app
SENDGRID_FROM_NAME=CONFIT

# SMTP fallback for password reset emails when SendGrid is not configured
# Gmail requires an App Password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=CONFIT

# SendGrid Dynamic Template IDs (create in SendGrid dashboard)
SENDGRID_TEMPLATE_ORDER_CONFIRMATION=d-xxxxx
SENDGRID_TEMPLATE_DONOR_RECEIPT=d-xxxxx
SENDGRID_TEMPLATE_COUPON_REDEEMED=d-xxxxx
SENDGRID_TEMPLATE_WELCOME=d-xxxxx
SENDGRID_TEMPLATE_PASSWORD_RESET=d-xxxxx
SENDGRID_TEMPLATE_DELIVERY_UPDATE=d-xxxxx
