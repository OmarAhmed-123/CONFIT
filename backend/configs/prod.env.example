# CONFIT Production Environment Configuration
# ============================================
# Template for production deployment with GPU.
# Copy this file to prod.env and fill in values.

# ==========================================
# INFERENCE MODE (CRITICAL)
# ==========================================
# gpu = Use real GPU inference
INFERENCE_MODE=gpu

# ==========================================
# APPLICATION SETTINGS
# ==========================================
DEBUG=false
LOG_LEVEL=info
SECRET_KEY=${SECRET_KEY}  # Set via environment or secrets manager

# ==========================================
# DATABASE (Production)
# ==========================================
DATABASE_URL=postgresql://user:password@db:5432/confit

# ==========================================
# REDIS (Required for Celery)
# ==========================================
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

# ==========================================
# CORS (Production)
# ==========================================
CORS_ORIGINS=https://your-domain.com
CORS_ALLOW_CREDENTIALS=true

# ==========================================
# FILE STORAGE
# ==========================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ==========================================
# GPU SETTINGS
# ==========================================
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.8
MODEL_WEIGHTS_PATH=/app/weights

# ==========================================
# MODEL PATHS
# ==========================================
IDM_VTON_PATH=/app/weights/idm_vton
VITON_HD_PATH=/app/weights/viton_hd
SAM_CHECKPOINT=/app/weights/sam_vit_h.pth

# ==========================================
# CELERY SETTINGS
# ==========================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=2
CELERY_MAX_TASKS_PER_CHILD=10

# ==========================================
# HUGGINGFACE (Fallback)
# ==========================================
HUGGINGFACE_TOKEN=${HUGGINGFACE_TOKEN}
HUGGINGFACE_FALLBACK_ENABLED=true

# ==========================================
# MONITORING
# ==========================================
ENABLE_METRICS=true
ENABLE_TRACING=true
PROMETHEUS_PORT=9090

# ==========================================
# SECURITY
# ==========================================
API_KEY_HEADER=X-API-Key
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
