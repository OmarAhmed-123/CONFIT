# ─────────────────────────────────────────────────────────────────────────────
# CONFIT Security Integration — Required Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control!

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS (Required for PentAGI)
# ─────────────────────────────────────────────────────────────────────────────

# DeepSeek API (Primary AI Provider)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_SERVER_URL=https://api.deepseek.com

# OpenAI API (Alternative Provider)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude API (Alternative Provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google Gemini API (Alternative Provider)
GOOGLE_API_KEY=AIza-your-google-api-key

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY INTELLIGENCE APIs (Optional but Recommended)
# ─────────────────────────────────────────────────────────────────────────────

# Shodan API (Network Intelligence)
SHODAN_API_KEY=your-shodan-api-key

# VirusTotal API (Threat Intelligence)
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# ─────────────────────────────────────────────────────────────────────────────
# PENTAGI CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# PentAGI Server URL (internal Docker network)
PENTAGI_URL=https://pentagi:8443

# PentAGI API Token (generate from PentAGI Settings > API Tokens)
PENTAGI_API_TOKEN=your-secure-api-token-here

# SSL Verification (set to false for development)
PENTAGI_SSL_VERIFY=false

# PentAGI Server Port (default: 8443)
PENTAGI_PORT=8443

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Default pentest container images
DOCKER_DEFAULT_IMAGE=debian:latest
DOCKER_DEFAULT_IMAGE_FOR_PENTEST=vxcontrol/kali-linux

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# NOTE: Never commit real API keys. Populate secrets via your local `.env` / CI secrets store.
